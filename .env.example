# AIMED Secretary Configuration

# === LLM Provider ===
# "claude-code" | "ollama"
LLM_PROVIDER=claude-code
CLAUDE_CLI_PATH=claude

# Ollama (if using ollama provider)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# === Channels ===
# Discord (get token from https://discord.com/developers/applications)
# DISCORD_TOKEN=

# Telegram (get token from @BotFather)
# TELEGRAM_TOKEN=

# Slack (get tokens from https://api.slack.com/apps)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=
# SLACK_APP_TOKEN=xapp-...
# SLACK_PORT=3100

# === Server ===
WEBHOOK_PORT=18790

# === Database ===
DB_PATH=./data/aimed.db

# === Logging ===
# debug | info | warn | error
LOG_LEVEL=info
